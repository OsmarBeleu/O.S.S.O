<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OSSO.Client.ViewModels.Auth"
             x:Class="OSSO.Client.Views.Auth.LoginView"
             x:DataType="vm:LoginViewModel">
    <Grid VerticalAlignment="Center"
          HorizontalAlignment="Center"
          Width="320"
          RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
        <TextBlock Grid.Row="0" Text="O.S.S.O" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,8"/>
        <TextBlock Grid.Row="1" Text="Faca login para continuar" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,32"/>
        <TextBox Grid.Row="2" Text="{Binding Username}" PlaceholderText="Usuario" Margin="0,0,0,12"/>
        <TextBox Grid.Row="3" Text="{Binding Password}" PasswordChar="*" PlaceholderText="Senha" Margin="0,0,0,8"/>
        <TextBlock Grid.Row="4" Text="{Binding ErrorMessage}" Foreground="Red" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,12"/>
        <Button Grid.Row="5" Content="Entrar" Command="{Binding LoginCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
    </Grid>
</UserControl>
