{
    "configurations": [
        {
            "name": "C/C++ Debug: Launch with GDB",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/out/build/GCC 13.3.0 x86_64-linux-gnu/OSSO",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "MIMode": "gdb",
            "preLaunchTask": "CMake: build",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
   
}